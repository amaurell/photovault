# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:6153

# Database
DATABASE_URL=postgresql://photovault:photovault@localhost:5432/photovault?schema=public

# Auth
JWT_SECRET=change-me-jwt-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
COOKIE_SECRET=change-me-cookie-secret-min-32-chars!!
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Admin seed
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=Admin123!

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=20971520

# Logs
LOG_LEVEL=info

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Vercel (optional — apenas quando deploy na Vercel)
# VERCEL=1  # Automático, não definir manualmente
# VERCEL_BLOB_URL=  # Preenchido automaticamente pelo @vercel/blob
# BLOB_READ_WRITE_TOKEN=  # Gerado no dashboard da Vercel (Storage > Blob)
